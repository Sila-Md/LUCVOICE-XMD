{
  "name": "𝐋𝐔𝐂𝐕𝐎𝐈𝐂𝐄-𝐗𝐌𝐃",
  "description": "WhatsApp bot made by BIN ADNAN",
  "logo": "https://files.catbox.moe/8a9abd.png",
  "keywords": ["𝐋𝐔𝐂𝐕𝐎𝐈𝐂𝐄-𝐗𝐌𝐃"],
  "success_url": "/",

  "stack": "container",
  "env": {
 "SESSION_ID": {
      "description": "Put your session id here",
      "required": true
    },
    "OWNER_NAME": {
      "description": "Owner name",
      "value": "LUKA iT"
    },
    "OWNER_NUMBER": {
      "description": "Owner WhatsApp number (255xxxxxxxxx)",
      "value": "255XXXXXXXXX"
    },
    "BOT_NAME": {
      "description": "Bot name",
      "value": "LUCVOICE-XMD"
    },
    "PREFIX": {
      "description": "Command prefix",
      "value": "."
    },
    "MODE": {
      "description": "Bot mode (public/private)",
      "value": "public"
    },
    "PRESENCE": {
      "description": "Bot presence (online/typing/recording)",
      "value": "online"
    },
    "ALWAYS_ONLINE": {
      "description": "Keep bot always online",
      "value": "true"
    },
    "MENU_IMAGE": {
      "description": "Menu image url",
      "value": "https://files.catbox.moe/xyz123.jpg"
    },
    "AUTO_READ": {
      "description": "Auto read messages (true/false)",
      "value": "true"
    },
    "AUTO_STATUS_SEEN": {
      "description": "Auto view status",
      "value": "true"
    },
    "AUTO_REACT_STATUS": {
      "description": "Auto react to status (true/false)",
      "value": "true"
    },
    "ANTI_DELETE": {
      "description": "Prevent message delete",
      "value": "true"
    },
    "ANTI_CALL": {
      "description": "Block calls automatically",
      "value": "false"
    },
    "READ_MESSAGE": {
      "description": "Mark messages as read",
      "value": "true"
    },
    "CHATBOT": {
      "description": "Custom chatbot feature name",
      "value": "CHATBOT"
    },
    "WARN_COUNT": {
      "description": "Count of warnings for users",
      "value": "2"
    }


    },

     "buildpacks": [
        {
            "url": "https://github.com/heroku/heroku-buildpack-nodejs.git"
        }
     ],
  "stack": "heroku-24"
}
